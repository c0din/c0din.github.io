  },
  "entries": [
    {
      "id": "S001",
      "work": "Letters to Lucilius",
      "letter": "1",
      "text": { "english": "It is not that we have a short time to live, but that we waste a lot of it." }
    },
    {
      "id": "S002",
      "work": "Letters to Lucilius",
      "letter": "2",
      "text": { "english": "To be everywhere is to be nowhere." }
    },
    {
      "id": "S003",
      "work": "On the Shortness of Life",
      "chapter": "1",
      "text": { "english": "Life is long if you know how to use it." }
    },
    {
      "id": "S004",
      "work": "Letters to Lucilius",
      "letter": "16",
      "text": { "english": "Philosophy is not a matter of words, but of deeds." }
    },
    {
      "id": "S005",
      "work": "On Anger",
      "chapter": "II.36",
      "text": { "english": "The best remedy for anger is delay." }
    },
    {
      "id": "S006",
      "work": "Letters to Lucilius",
      "letter": "77",
      "text": { "english": "Sometimes even to live is an act of courage." }
    },
    {
      "id": "S007",
      "work": "On Providence",
      "chapter": "4",
      "text": { "english": "Fire tests gold, suffering tests brave men." }
    },
    {
      "id": "S008",
      "work": "Letters to Lucilius",
      "letter": "107",
      "text": { "english": "Willing obedience is better than forced compliance." }
    }
  ]
}
