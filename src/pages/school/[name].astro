---
import Layout from '../../layouts/Layout.astro';
import QuoteGenerator from '../../components/QuoteGenerator.astro';

type Theme = 'stoicism' | 'cynicism' | 'tactical' | 'athanor' | 'stream' | 'dialectic' | 'clearing';

const schools: Record<string, { title: string; subtitle: string; ids: string[]; theme: Theme }> = {
  stoicism: { title: 'The Porch',   subtitle: 'Stoicism', ids: ['marcus', 'epictetus', 'seneca'], theme: 'stoicism' },
  cynicism: { title: 'The Barrel',  subtitle: 'Cynicism', ids: ['diogenes'],                      theme: 'cynicism' },
  tactical: { title: 'The Dojo',    subtitle: 'Tactical', ids: ['musashi'],                       theme: 'tactical' },
  athanor:  { title: 'The Athanor',     subtitle: 'Depth',     ids: ['jung'],   theme: 'athanor'  },
  stream:   { title: 'The Stream',      subtitle: 'Taoism',    ids: ['laozi'],  theme: 'stream'   },
  dialectic:        { title: 'The Beth Midrash', subtitle: 'Dialectic',        ids: ['sages'],   theme: 'dialectic' },
  clearing:         { title: 'The Clearing',     subtitle: 'Transcendentalism', ids: ['thoreau'], theme: 'clearing'  },
};

const { name } = Astro.params;
const school = schools[name as string];

if (!school) return Astro.redirect('/404');
---

<Layout title={`c0din | ${school.subtitle}`} theme={school.theme}>
  <a href="/" class="atrium-back">← The Atrium</a>

  <main class="min-h-screen flex items-center justify-center">
    <QuoteGenerator ids={school.ids} />
  </main>
</Layout>

<style>
  .atrium-back {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 50;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--back-link, rgba(255, 255, 255, 0.25));
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .atrium-back:hover {
    color: var(--back-link-hover, rgba(255, 255, 255, 0.7));
  }
</style>
